# ============================================
# LONDRA VETERİNER - Next.js .gitignore
# ============================================

# Dependencies
node_modules/
/.pnp
.pnp.js
.yarn/

# Testing
/coverage
*.test.js
*.spec.js

# Next.js
/.next/
/out/
.next/

# Production
/build
/dist

# Misc
.DS_Store
*.pem
Thumbs.db

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# Environment Variables
.env
.env.local
.env*.local
.env.development.local
.env.test.local
.env.production.local

# Vercel
.vercel
.vercel.json

# TypeScript
*.tsbuildinfo
next-env.d.ts

# IDE / Editor
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace
.history/

# OS Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Logs
logs/
*.log

# Temporary files
*.tmp
*.temp
.cache/
.temp/
tmp/

# Package manager lock files (keep these)
# Uncomment if you want to ignore lock files
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Public uploads (if you have user-generated content)
# /public/uploads/
# /public/images/uploads/

# Backup files
*.bak
*.backup
*~
*.orig

# ESLint
.eslintcache

# Turbopack
.turbo/

# Sentry
.sentryclirc

# Local development
.local/node_modules/
